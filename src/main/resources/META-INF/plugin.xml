<?xml version="1.0" encoding="UTF-8" ?>
<idea-plugin>
    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.gradle</depends>
    <depends>com.intellij.modules.java</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <languageInjector implementation="dev.kikugie.stonecutter.intellij.impl.StitcherInjector"/>
        <colorSettingsPage implementation="dev.kikugie.stonecutter.intellij.impl.StitcherColorSettingsPage"/>
        <editorHighlighterProvider filetype="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherEditorHighlighter"/>
        <fileTypeOverrider implementation="dev.kikugie.stonecutter.intellij.impl.StitcherFileTypeOverrider"/>
        <lang.parserDefinition language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.lang.StitcherDef"/>
        <lang.syntaxHighlighter language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherHighlighter"/>
        <annotator language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherAnnotator"/>
        <lang.importOptimizer language="JAVA" order="first" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherImportManager"/>
        <codeInsight.lineMarkerProvider language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherLineMarkerProvider"/>
        <completion.contributor language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherCompletion"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.plugins.gradle">
        <projectResolve implementation="dev.kikugie.stonecutter.intellij.impl.ReloadListener"/>
    </extensions>
</idea-plugin>