<?xml version="1.0" encoding="UTF-8" ?>
<idea-plugin>
    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.gradle</depends>
    <depends>com.intellij.modules.java</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <colorSettingsPage implementation="dev.kikugie.stonecutter.intellij.impl.StitcherHighlighting$Settings"/>
        <editorHighlighterProvider filetype="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherHighlighting$Provider"/>
        <lang.parserDefinition language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.lang.StitcherParserDef"/>
        <lang.syntaxHighlighter language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherHighlighting$Highlighter"/>
        <annotator language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherAnnotator"/>
        <lang.importOptimizer language="JAVA" order="first" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherImportManager"/>
        <completion.contributor language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherCompletionContributor"/>
        <codeInsight.lineMarkerProvider language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.impl.StitcherLineMarker"/>
        <lang.fileViewProviderFactory language="Stitcher" implementationClass="dev.kikugie.stonecutter.intellij.lang.file.StitcherFileViewProvider$Factory"/>
        <lang.substitutor language="JAVA" implementationClass="dev.kikugie.stonecutter.intellij.lang.StitcherLanguageSubstitutor"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.plugins.gradle">
        <projectResolve implementation="dev.kikugie.stonecutter.intellij.impl.ReloadListener"/>
    </extensions>
</idea-plugin>